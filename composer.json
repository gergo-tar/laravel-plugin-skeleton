{
  "name": "gergo-tar/laravel-package-skeleton",
  "description": "A PHP package to scaffold Laravel package projects with best practices and code quality tools.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Gergő Tar",
      "email": "dev@gergotar.com",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/gergo-tar/laravel-package-skeleton",
  "keywords": [
    "laravel",
    "package",
    "skeleton",
    "scaffold",
    "php"
  ],
  "support": {
    "issues": "https://github.com/gergo-tar/laravel-package-skeleton/issues",
    "source": "https://github.com/gergo-tar/laravel-package-skeleton"
  },
  "autoload": {
    "psr-4": {
      "Configurator\\": "configurator/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "pestphp/pest": "^2.34",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^4.0",
    "friendsofphp/php-cs-fixer": "^3.93",
    "rector/rector": "^2.2",
    "vimeo/psalm": "^6.14"
  },
  "scripts": {
    "test": "pest",
    "stan": "phpstan analyse configurator tests --level=max",
    "cs": "phpcs configurator",
    "cs-fix": "php-cs-fixer fix configurator",
    "rector": "rector process configurator",
    "psalm": "psalm --show-info=true"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
